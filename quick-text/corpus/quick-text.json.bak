    {
      "categoryId" : "prompt-reuse",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "prompt-reuse-llmmeta",
      "tags" : [
        "llmmeta"
      ],
      "textReplacement" : {
        "shortcut" : "xmeta",
        "syncEnabled" : true
      },
      "title" : "Provide a meta prompt. Goal:",
      "updatedAt" : "2026-07-09T19:48:30Z",
      "value" : "Create a concise, high-performance meta-prompt to achieve my goal in a new chat. Write for an LLM using imperative language, without conversational filler or explanation. Keep it generic and portable, and refer to external materials with indirect labels such as \"the attached image” rather than specific filenames. \n\nGoal: ",
      "visibility" : "private"
    },
    {
      "categoryId" : "prompt-reuse",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "prompt-reuse-llmsum",
      "tags" : [
        "llmsum"
      ],
      "textReplacement" : {
        "shortcut" : "xsum",
        "syncEnabled" : false
      },
      "title" : "Summarize all context from this chat",
      "updatedAt" : "2026-07-09T22:12:05Z",
      "value" : "Create an LLM-optimized meta-prompt that captures the effective instructions, constraints, decisions, and workflow patterns from this session so they can be reused in a new chat. Keep it generic and portable. Refer to external materials only with indirect labels such as \"the attached image,” rather than specific filenames. Optimize for faithful replication of the setup.",
      "visibility" : "public"
    },
    {
      "categoryId" : "prompt-reuse",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "prompt-reuse-samefiles",
      "tags" : [
        "samefiles"
      ],
      "textReplacement" : {
        "shortcut" : "xattach",
        "syncEnabled" : true
      },
      "title" : "Same attachments provided",
      "updatedAt" : "2026-07-09T19:53:31Z",
      "value" : "Assume the same attachments or reference materials will be provided in the subsequent chat. ",
      "visibility" : "public"
    },
    {
      "categoryId" : "prompt-reuse",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "instruction-editing-llmformat",
      "tags" : [
        "llmformat"
      ],
      "textReplacement" : {
        "shortcut" : "xllm",
        "syncEnabled" : true
      },
      "title" : "Rewrite for an LLM",
      "updatedAt" : "2026-07-09T19:54:41Z",
      "value" : "Rewrite for concision and clarity without changing the meaning or effectiveness. Write for an LLM audience, using direct imperative language and removing human-oriented explanation or filler.",
      "visibility" : "public"
    },
    {
      "categoryId" : "prompt-reuse",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "instruction-editing-noneg",
      "summary" : "",
      "tags" : [
        "noneg"
      ],
      "textReplacement" : {
        "shortcut" : "xpositive",
        "syncEnabled" : true
      },
      "title" : "Restate as positive instructions; Avoid negative constructions",
      "updatedAt" : "2026-07-09T19:55:02Z",
      "value" : "Rewrite the instructions using positive, action-oriented requirements. Define what to do, what to produce, and how to perform the task using direct affirmative language. Avoid negative constructions",
      "visibility" : "public"
    },
    {
      "categoryId" : "prompt-reuse",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "instruction-editing-nofiles",
      "tags" : [
        "nofiles"
      ],
      "textReplacement" : {
        "shortcut" : "xfiles",
        "syncEnabled" : true
      },
      "title" : "Provide a portable response. No file names.",
      "updatedAt" : "2026-07-09T19:55:58Z",
      "value" : "Make the output self-contained and portable for reuse in a new context. Refer to provided materials indirectly, using labels such as \"the document,\" \"the subject,\" \"the image,\" or \"the reference material.\" Do not include filenames, system paths, chat-specific labels, or environment-specific references.",
      "visibility" : "public"
    },
    {
      "categoryId" : "response-style",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "response-style-nocontext",
      "tags" : [
        "nocontext"
      ],
      "textReplacement" : {
        "shortcut" : "xcontext",
        "syncEnabled" : true
      },
      "title" : "Respond with full context",
      "updatedAt" : "2026-07-09T19:56:45Z",
      "value" : "Generate a self-contained response that can be understood without prior conversation context. Include any necessary assumptions or framing directly in the response, and avoid references to earlier messages.",
      "visibility" : "public"
    },
    {
      "categoryId" : "response-style",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "response-style-nointro",
      "tags" : [
        "nointro"
      ],
      "textReplacement" : {
        "shortcut" : "xintro",
        "syncEnabled" : true
      },
      "title" : "Avoid commentary & filler",
      "updatedAt" : "2026-07-09T19:56:58Z",
      "value" : "Provide only the requested output. Omit introductions, acknowledgments, setup commentary, and closing remarks.",
      "visibility" : "public"
    },
    {
      "categoryId" : "response-style",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "response-style-ptext",
      "summary" : "",
      "tags" : [
        "ptext"
      ],
      "textReplacement" : {
        "shortcut" : "xprose",
        "syncEnabled" : true
      },
      "title" : "Prose formatting only. No lists.",
      "updatedAt" : "2026-07-02T21:46:43Z",
      "value" : "Respond in prose only, with no lists, tables, headers, or bullet points. Write naturally for spoken readability.",
      "visibility" : "private"
    },
