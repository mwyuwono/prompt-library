      "id" : "workflow-commands-llmlearn",
      "tags" : [
        "llmlearn"
      ],
      "textReplacement" : {
        "shortcut" : "xlearn",
        "syncEnabled" : true
      },
      "title" : "Capture durable learnings",
      "updatedAt" : "2026-07-02T22:14:35Z",
      "value" : "Review this session for durable learnings worth preserving: user preferences, reusable instructions, architecture decisions, debugging insights, project knowledge, workflow improvements, documentation updates, tests, runbooks, or backlog items. Propose additions or changes. Exclude temporary, speculative, redundant, or low-value details.",
      "visibility" : "public"
    },
