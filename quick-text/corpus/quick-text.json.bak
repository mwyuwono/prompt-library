    {
      "categoryId" : "image-quality",
      "createdAt" : "2026-07-02T21:07:02Z",
      "favorite" : false,
      "id" : "image-quality-llmnoise",
      "tags" : [
        "llmnoise"
      ],
      "textReplacement" : {
        "shortcut" : "xnoise",
        "syncEnabled" : true
      },
      "title" : "Minimize AI artifacts",
      "updatedAt" : "2026-07-02T22:13:01Z",
      "value" : "Avoid digital AI artifacts, moire patterns, pixel jitter, procedural noise grids, and repetitive synthetic textures. Ensure all textures, surfaces, and visual details match the physical realism of the requested medium, using organic variation, natural lens behavior, or authentic material-specific marks.",
      "visibility" : "private"
    },
    {
      "categoryId" : "workflow-commands",
      "createdAt" : "2026-07-02T21:52:52Z",
      "favorite" : true,
      "id" : "prompt-reuse-subjectagnostic-copy-1783029172",
      "summary" : "",
      "tags" : [
        "subjectagnostic"
      ],
      "textReplacement" : {
        "shortcut" : "xreuse",
        "syncEnabled" : true
      },
      "title" : "Turn a chat into a reusable prompt",
      "updatedAt" : "2026-07-03T01:25:07Z",
      "value" : "Convert this chat into a durable, reusable meta-prompt.\n\nExtract Core Mechanism: Retain the underlying task, transformations, style, tone, constraints, output format, and workflow that made the original prompt effective.\n\nAbstract Specifics: Replace all case-specific details (subjects, places, persons, objects, mediums) with clear variables and static anchors.\n\nPrevent Overfitting: Ensure the generalized prompt functions effectively when applied to entirely different subjects or use cases.\n\nProvide the meta prompt. ",
      "visibility" : "private"
    },
