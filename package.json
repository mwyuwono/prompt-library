{
  "name": "prompt-library-admin",
  "version": "1.0.0",
  "description": "Admin server for Prompts Library",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:components": "esbuild components/ui/index.js --bundle --format=esm --target=es2020 --outfile=web-components.js",
    "validate:prompts": "node validate-prompts.js",
    "check": "npm run validate:prompts && npm run build:components",
    "encrypt:private": "node scripts/encrypt-private-prompts.mjs",
    "quicktext:validate": "node quick-text/scripts/validate-corpus.mjs",
    "quicktext:export-public": "node quick-text/scripts/export-public-corpus.mjs",
    "quicktext:extract-palette": "node quick-text/scripts/extract-palette.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "lit": "^3.3.2",
    "marked": "^18.0.5",
    "playwright": "^1.59.1"
  }
}
